# ============================================================
# Slipway Platform - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables are required unless marked [optional].
# ============================================================

# === Proxmox VE ===
PROXMOX_URL=https://pve.example.com:8006
PROXMOX_TOKEN=root@pam!capi
PROXMOX_SECRET=your-api-token-secret
PROXMOX_NODE=pve
PROXMOX_TEMPLATE_ID=9000

# === Management Cluster Networking ===
MGMT_VIP=10.10.0.10
MGMT_IP_RANGE=10.10.0.11-10.10.0.19
MGMT_GATEWAY=10.10.0.1
MGMT_PREFIX=20
MGMT_VLAN_TAG=2

# === Cilium LB IP Pool ===
LB_IP_POOL_CIDR=10.10.1.0/24

# === Cloudflare ===
CF_API_TOKEN=your-cloudflare-api-token
CF_DOMAIN=example.com
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# === Secret Store (External Secrets Operator) ===
# Choose one backend and fill in the relevant variables.
#
# Option 1: 1Password Connect
# OP_CONNECT_TOKEN=your-1password-connect-token
# OP_CONNECT_HOST=https://connect.your-domain.com
# OP_VAULT_ID=your-vault-id
#
# Option 2: Infisical (self-hosted or cloud)
# INFISICAL_TOKEN=your-infisical-service-token
# INFISICAL_HOST=https://infisical.your-domain.com
#
# Option 3: Doppler
# DOPPLER_TOKEN=your-doppler-service-token

# === Talos Linux ===
TALOS_VERSION=v1.11.0
KUBERNETES_VERSION=v1.32.0
# Schematic ID from factory.talos.dev (includes qemu-guest-agent + iscsi-tools)
TALOS_SCHEMATIC_ID=your-schematic-id

# === DNS ===
DNS_SERVERS=1.1.1.1,8.8.8.8
